{
  "manifest_version": 3,
  "name": "CosmosGlimpse",
  "version": "1.0.1",
  "description": "Every new tab — a random window into the galaxy. Powered by NASA.",

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://cosmosglimpse-worker.cosmosglimpse.workers.dev/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [{
    "resources": ["saved.html", "saved.css", "saved.js"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}